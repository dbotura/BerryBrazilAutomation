# Neon Database Connection
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Resend Email API Key (get from https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Vercel Blob Storage Token (auto-generated by Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Company Email (sender address - must be verified in Resend)
COMPANY_EMAIL=invoices@yourdomain.com

# Company Details (for invoice)
COMPANY_NAME=Berry Brazil Açai
COMPANY_ADDRESS=Your Address Here
COMPANY_PHONE=Your Phone
COMPANY_TAX_ID=Your Tax ID
