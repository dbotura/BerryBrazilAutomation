# Neon Database Connection
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Resend Email API Key (get from https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Vercel Blob Storage Token (auto-generated by Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Google Drive invoice storage
GOOGLE_DRIVE_ENABLED=false

# Use this in local/test mode when you want invoice PDFs to land in a test folder.
GOOGLE_DRIVE_TEST_FOLDER_ID=your_google_drive_test_folder_id

# Use this for production uploads when INVOICE_TEST_MODE is false.
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_production_folder_id

# Option 1: OAuth refresh-token credentials
# Best for a personal My Drive folder that belongs to your Google account.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# Option 2: Service account credentials
# Best for a Shared Drive, or a folder explicitly shared with the service account.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=invoice-drive-uploader@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Company Email (sender address - must be verified in Resend)
COMPANY_EMAIL=invoices@yourdomain.com

# Company Details (for invoice)
COMPANY_NAME=Berry Brazil Açai
COMPANY_ADDRESS=Your Address Here
COMPANY_PHONE=Your Phone
COMPANY_TAX_ID=Your Tax ID
